# Godot 4+ specific ignores
.godot/
/android/
*.translation

# Vendored reference sources (not shipped)
/vendor/

# Local prototypes / scratch scenes (not shipped)
/prototypes/pong/

# Local-only architecture / design docs — not committed, not imported by
# Godot. The .gdignore inside the folder keeps Godot's resource scanner
# out of any .md / scratch files we drop here.
/design/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo

# Backups & scratch
*.bak
*.tmp
*.orig

# Godette: pasted clipboard images + drag-dropped blobs. Per-machine
# scratch, not project content. The attachments/ folder also ships with
# its own .gitignore so end-user projects get the rule automatically;
# this entry keeps the dev repo clean while still tracking the folder's
# .gitignore + .gdignore.
/addons/godette_agent/attachments/*
!/addons/godette_agent/attachments/.gitignore
!/addons/godette_agent/attachments/.gdignore
